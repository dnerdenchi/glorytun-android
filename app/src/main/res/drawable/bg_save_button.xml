<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40adc6ff">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#1a3a6e"
                android:endColor="#4b8eff"
                android:type="linear"/>
            <corners android:radius="14dp"/>
            <stroke
                android:width="1dp"
                android:color="#55adc6ff"/>
        </shape>
    </item>
</ripple>
