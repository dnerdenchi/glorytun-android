<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <!-- プロファイル名 + アクティブ表示 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/on_surface"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_active_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● アクティブ"
            android:textColor="@color/tertiary"
            android:textSize="11sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- サーバー情報 + 疎通確認ステータス（横並び） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/tv_profile_server"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp" />

        <!-- 疎通確認ステータス（右端） -->
        <TextView
            android:id="@+id/tv_server_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/on_surface_variant"
            android:visibility="gone" />

    </LinearLayout>

    <!-- アクションボタン（接続→確認→編集→削除） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_connect_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="接続"
            android:textSize="12sp"
            android:backgroundTint="@color/primary"
            android:textColor="@color/on_primary"
            app:cornerRadius="6dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_check_server"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="確認"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/outline"
            app:cornerRadius="6dp"
            android:textColor="@color/on_surface_variant"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_edit_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="編集"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/outline"
            app:cornerRadius="6dp"
            android:textColor="@color/on_surface_variant"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_delete_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="削除"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/error"
            app:cornerRadius="6dp"
            android:textColor="@color/error" />

    </LinearLayout>

</LinearLayout>
