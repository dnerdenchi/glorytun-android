<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ヘッダー -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_nav_bonding"
                app:tint="@color/primary"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BondVPN"
                android:textColor="@color/on_surface"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- 接続ステータスバッジ -->
            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未接続"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_card" />

        </LinearLayout>

        <!-- 接続ボタン・ステータスカード -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:gravity="center_horizontal"
            android:layout_marginBottom="16dp">

            <!-- 大きな接続ボタン -->
            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="20dp">

                <View
                    android:id="@+id/connect_button_bg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_connect_button" />

                <Button
                    android:id="@+id/btn_connect"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="接続"
                    android:textColor="@color/on_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="@android:color/transparent"
                    android:stateListAnimator="@null" />
            </FrameLayout>

            <!-- ステータステキスト -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未接続"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <!-- サーバー情報 -->
            <TextView
                android:id="@+id/tv_server_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="サーバー: 未設定"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- スピードメトリクスカード -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Wi-Fi スピード -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginEnd="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@color/tertiary"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wi-Fi"
                        android:textColor="@color/tertiary"
                        android:textSize="11sp"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_wifi_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- KB/s"
                    android:textColor="@color/on_surface"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_wifi_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="合計: --"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- SIM スピード -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginStart="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@color/secondary"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIM"
                        android:textColor="@color/secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_sim_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- KB/s"
                    android:textColor="@color/on_surface"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_sim_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="合計: --"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- リアルタイムグラフカード -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="リアルタイム通信量"
                    android:textColor="@color/on_surface"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Wi-Fi 凡例 -->
                <View
                    android:layout_width="12dp"
                    android:layout_height="3dp"
                    android:background="@color/tertiary"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wi-Fi"
                    android:textColor="@color/tertiary"
                    android:textSize="11sp"
                    android:layout_marginEnd="12dp" />

                <!-- SIM 凡例 -->
                <View
                    android:layout_width="12dp"
                    android:layout_height="3dp"
                    android:background="@color/secondary"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIM"
                    android:textColor="@color/secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.example.glorytun.TrafficGraphView
                android:id="@+id/traffic_graph"
                android:layout_width="match_parent"
                android:layout_height="140dp" />

        </LinearLayout>

        <!-- セッション統計カード -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="セッション統計"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="合計転送量"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tv_total_data"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 MB"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="パケットロス"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tv_packet_loss"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- %"
                        android:textColor="@color/on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="遅延"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tv_latency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- ms"
                        android:textColor="@color/on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
