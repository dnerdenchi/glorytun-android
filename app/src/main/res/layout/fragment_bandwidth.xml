<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ヘッダー -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_chevron_right"
                android:rotation="180"
                app:tint="@color/on_surface_variant"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="帯域幅管理"
                    android:textColor="@color/on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="インターフェース別・データ通信量制限"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ===== WiFi セクション ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WiFi"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <!-- WiFi アイコン行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@color/wifi_color"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WiFi 制限設定"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- WiFi 月間 トグル行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="月間制限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_wifi_monthly_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="無効"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_wifi_monthly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- WiFi 月間 詳細パネル -->
            <LinearLayout
                android:id="@+id/panel_wifi_monthly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- 月間データ上限 ラベル行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="月間データ上限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_wifi_monthly_limit_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30 GB"
                        android:textColor="@color/wifi_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- WiFi月間上限 プリセットチップ -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:id="@+id/chips_wifi_monthly_limit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />
                </HorizontalScrollView>

                <!-- WiFi月間上限 スライダー -->
                <SeekBar
                    android:id="@+id/seekbar_wifi_monthly_limit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/wifi_color"
                    android:thumbTint="@color/wifi_color"
                    android:layout_marginBottom="2dp" />

                <!-- WiFi月間上限 カスタム入力 -->
                <LinearLayout
                    android:id="@+id/custom_wifi_monthly_limit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="8dp">

                    <EditText
                        android:id="@+id/et_wifi_monthly_limit"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:inputType="numberDecimal"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:hint="値を入力"
                        android:textColorHint="@color/outline"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GB"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- 超過後速度 ラベル行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="超過後の速度制限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_wifi_monthly_throttle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 Mbps"
                        android:textColor="@color/wifi_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- WiFi月間速度 プリセットチップ -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:id="@+id/chips_wifi_monthly_throttle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />
                </HorizontalScrollView>

                <!-- WiFi月間速度 スライダー -->
                <SeekBar
                    android:id="@+id/seekbar_wifi_monthly_throttle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/wifi_color"
                    android:thumbTint="@color/wifi_color"
                    android:layout_marginBottom="2dp" />

                <!-- WiFi月間速度 カスタム入力 -->
                <LinearLayout
                    android:id="@+id/custom_wifi_monthly_throttle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginTop="6dp">

                    <EditText
                        android:id="@+id/et_wifi_monthly_throttle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:inputType="numberDecimal"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:hint="値を入力"
                        android:textColorHint="@color/outline"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="kbps / Mbps"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 月間/1日 区切り線 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/outline_variant"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp" />

            <!-- WiFi 1日 トグル行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1日制限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_wifi_daily_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="無効"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_wifi_daily"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- WiFi 1日 詳細パネル -->
            <LinearLayout
                android:id="@+id/panel_wifi_daily"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- 1日データ上限 ラベル行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1日データ上限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_wifi_daily_limit_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 GB"
                        android:textColor="@color/wifi_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- WiFi1日上限 プリセットチップ -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:id="@+id/chips_wifi_daily_limit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />
                </HorizontalScrollView>

                <!-- WiFi1日上限 スライダー -->
                <SeekBar
                    android:id="@+id/seekbar_wifi_daily_limit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/wifi_color"
                    android:thumbTint="@color/wifi_color"
                    android:layout_marginBottom="2dp" />

                <!-- WiFi1日上限 カスタム入力 -->
                <LinearLayout
                    android:id="@+id/custom_wifi_daily_limit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="8dp">

                    <EditText
                        android:id="@+id/et_wifi_daily_limit"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:inputType="numberDecimal"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:hint="値を入力"
                        android:textColorHint="@color/outline"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MB / GB"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- 超過後速度 ラベル行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="超過後の速度制限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_wifi_daily_throttle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 Mbps"
                        android:textColor="@color/wifi_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- WiFi1日速度 プリセットチップ -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:id="@+id/chips_wifi_daily_throttle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />
                </HorizontalScrollView>

                <!-- WiFi1日速度 スライダー -->
                <SeekBar
                    android:id="@+id/seekbar_wifi_daily_throttle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/wifi_color"
                    android:thumbTint="@color/wifi_color"
                    android:layout_marginBottom="2dp" />

                <!-- WiFi1日速度 カスタム入力 -->
                <LinearLayout
                    android:id="@+id/custom_wifi_daily_throttle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginTop="6dp">

                    <EditText
                        android:id="@+id/et_wifi_daily_throttle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:inputType="numberDecimal"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:hint="値を入力"
                        android:textColorHint="@color/outline"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="kbps / Mbps"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ===== SIM セクション ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIM"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <!-- SIM アイコン行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@color/sim_color"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIM 制限設定"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- SIM 月間 トグル行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="月間制限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_sim_monthly_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="無効"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_sim_monthly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- SIM 月間 詳細パネル -->
            <LinearLayout
                android:id="@+id/panel_sim_monthly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- 月間データ上限 ラベル行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="月間データ上限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_sim_monthly_limit_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30 GB"
                        android:textColor="@color/sim_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- SIM月間上限 プリセットチップ -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:id="@+id/chips_sim_monthly_limit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />
                </HorizontalScrollView>

                <!-- SIM月間上限 スライダー -->
                <SeekBar
                    android:id="@+id/seekbar_sim_monthly_limit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/sim_color"
                    android:thumbTint="@color/sim_color"
                    android:layout_marginBottom="2dp" />

                <!-- SIM月間上限 カスタム入力 -->
                <LinearLayout
                    android:id="@+id/custom_sim_monthly_limit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="8dp">

                    <EditText
                        android:id="@+id/et_sim_monthly_limit"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:inputType="numberDecimal"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:hint="値を入力"
                        android:textColorHint="@color/outline"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GB"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- 超過後速度 ラベル行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="超過後の速度制限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_sim_monthly_throttle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 Mbps"
                        android:textColor="@color/sim_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- SIM月間速度 プリセットチップ -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:id="@+id/chips_sim_monthly_throttle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />
                </HorizontalScrollView>

                <!-- SIM月間速度 スライダー -->
                <SeekBar
                    android:id="@+id/seekbar_sim_monthly_throttle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/sim_color"
                    android:thumbTint="@color/sim_color"
                    android:layout_marginBottom="2dp" />

                <!-- SIM月間速度 カスタム入力 -->
                <LinearLayout
                    android:id="@+id/custom_sim_monthly_throttle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginTop="6dp">

                    <EditText
                        android:id="@+id/et_sim_monthly_throttle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:inputType="numberDecimal"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:hint="値を入力"
                        android:textColorHint="@color/outline"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="kbps / Mbps"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 月間/1日 区切り線 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/outline_variant"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp" />

            <!-- SIM 1日 トグル行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1日制限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_sim_daily_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="無効"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_sim_daily"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- SIM 1日 詳細パネル -->
            <LinearLayout
                android:id="@+id/panel_sim_daily"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- 1日データ上限 ラベル行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1日データ上限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_sim_daily_limit_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 GB"
                        android:textColor="@color/sim_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- SIM1日上限 プリセットチップ -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:id="@+id/chips_sim_daily_limit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />
                </HorizontalScrollView>

                <!-- SIM1日上限 スライダー -->
                <SeekBar
                    android:id="@+id/seekbar_sim_daily_limit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/sim_color"
                    android:thumbTint="@color/sim_color"
                    android:layout_marginBottom="2dp" />

                <!-- SIM1日上限 カスタム入力 -->
                <LinearLayout
                    android:id="@+id/custom_sim_daily_limit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="8dp">

                    <EditText
                        android:id="@+id/et_sim_daily_limit"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:inputType="numberDecimal"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:hint="値を入力"
                        android:textColorHint="@color/outline"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MB / GB"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- 超過後速度 ラベル行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="超過後の速度制限"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_sim_daily_throttle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 Mbps"
                        android:textColor="@color/sim_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- SIM1日速度 プリセットチップ -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:id="@+id/chips_sim_daily_throttle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />
                </HorizontalScrollView>

                <!-- SIM1日速度 スライダー -->
                <SeekBar
                    android:id="@+id/seekbar_sim_daily_throttle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/sim_color"
                    android:thumbTint="@color/sim_color"
                    android:layout_marginBottom="2dp" />

                <!-- SIM1日速度 カスタム入力 -->
                <LinearLayout
                    android:id="@+id/custom_sim_daily_throttle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginTop="6dp">

                    <EditText
                        android:id="@+id/et_sim_daily_throttle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:inputType="numberDecimal"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:hint="値を入力"
                        android:textColorHint="@color/outline"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="kbps / Mbps"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- 保存ボタン -->
        <LinearLayout
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_save_button"
            android:clickable="true"
            android:focusable="true"
            android:elevation="2dp"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_nav_stats"
                app:tint="@color/on_primary"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="設定を保存"
                android:textColor="@color/on_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
